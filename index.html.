  {w:"zenith",s:"Winning both the academic decathlon and the regional championship in the same year felt like the absolute <strong>zenith</strong> of everything the school had been building toward.",p:"noun",d:"The highest point; the peak.",e:"Winning both the academic and athletic awards in the same ceremony felt like the absolute zenith of four years of work."},
  {w:"zephyr",s:"A welcome <strong>zephyr</strong> drifted through the open classroom window on the last Friday before summer — the whole room seemed to quietly exhale.",p:"noun",d:"A soft, gentle breeze.",e:"A welcome zephyr drifted through the classroom window on the last Friday before summer — the whole room seemed to exhale."}
];

const COLORS = [
  ["#7C6FD4","#EAE8F9"],["#1A9E75","#DCF5EC"],["#D85530","#FAEAE6"],
  ["#C94E7A","#FAE8F0"],["#2E7FCC","#E3EEF8"],["#5E9E1A","#EAF3DC"],
  ["#C07010","#FAECD8"],["#D44545","#FAE8E8"],["#7A7872","#EEECE6"]
];

const SEGS = 12;
let remaining = [...ALL];
let spinning = false;
let angle = 0;

const canvas = document.getElementById("wheel");
const ctx = canvas.getContext("2d");
const CX = 170, CY = 170, R = 158;

function updateCounter() {
  const used = ALL.length - remaining.length;
  document.getElementById("counter").textContent =
    remaining.length > 0
      ? `${remaining.length} words remaining · ${used} used`
      : `All ${ALL.length} words used — click Reset to start again`;
  document.getElementById("spinBtn").disabled = remaining.length === 0;
}

function drawWheel(a) {
  ctx.clearRect(0, 0, 340, 340);
  const pool = remaining.length > 0 ? remaining : ALL;
  const seg = (2 * Math.PI) / SEGS;
  for (let i = 0; i < SEGS; i++) {
    const s = a + i * seg, e = s + seg;
    const c = COLORS[i % COLORS.length];
    ctx.beginPath(); ctx.moveTo(CX, CY); ctx.arc(CX, CY, R, s, e); ctx.closePath();
    ctx.fillStyle = c[0]; ctx.fill();
    ctx.strokeStyle = "#fff"; ctx.lineWidth = 2.5; ctx.stroke();
    ctx.save(); ctx.translate(CX, CY); ctx.rotate(s + seg / 2);
    ctx.textAlign = "right"; ctx.fillStyle = c[1];
    ctx.font = "600 11px -apple-system, sans-serif";
    const label = pool[Math.floor((pool.length / SEGS) * i)].w;
    ctx.fillText(label, R - 10, 4);
    ctx.restore();
  }
  // center circle
  ctx.beginPath(); ctx.arc(CX, CY, 44, 0, 2 * Math.PI);
  ctx.fillStyle = "#fff"; ctx.fill();
  ctx.strokeStyle = "#e8e8e8"; ctx.lineWidth = 1.5; ctx.stroke();
  // center dot
  ctx.beginPath(); ctx.arc(CX, CY, 6, 0, 2 * Math.PI);
  ctx.fillStyle = "#ddd"; ctx.fill();
}

function easeOut(t) { return 1 - Math.pow(1 - t, 4); }

function doSpin() {
  if (spinning || remaining.length === 0) return;
  spinning = true;
  document.getElementById("spinBtn").disabled = true;

  const wi = Math.floor(Math.random() * remaining.length);
  const winner = remaining[wi];
  const totalSpin = (7 + Math.random() * 5) * 2 * Math.PI;
  const duration = 3500 + Math.random() * 800;
  const startAngle = angle;
  const startTime = performance.now();

  document.getElementById("card").innerHTML = `<p id="spinning-msg">Spinning...</p>`;

  function frame(now) {
    const t = Math.min((now - startTime) / duration, 1);
    angle = startAngle + totalSpin * easeOut(t);
    drawWheel(angle);
    if (t < 1) {
      requestAnimationFrame(frame);
    } else {
      remaining.splice(wi, 1);
      spinning = false;
      updateCounter();
      drawWheel(angle);
      showWord(winner);
    }
  }
  requestAnimationFrame(frame);
}

function showWord(word) {
  document.getElementById("card").innerHTML = `
    <p class="label">Word of the Day</p>
    <p class="word">${word.w}</p>
    <p class="sentence">${word.s}</p>
    <div id="reveal-area">
      <button class="reveal-btn" id="revBtn" onclick="revealDef()">Reveal definition &amp; part of speech</button>
      <div class="def-box" id="def-box" style="display:none">
        <p class="pos-tag">${word.p}</p>
        <p class="definition">${word.d}</p>
        <p class="example">${word.e}</p>
      </div>
    </div>`;
}

function revealDef() {
  document.getElementById("def-box").style.display = "block";
  document.getElementById("revBtn").style.display = "none";
}

function doReset() {
  remaining = [...ALL];
  updateCounter();
  drawWheel(angle);
  document.getElementById("card").innerHTML = `<p class="placeholder">All ${ALL.length} words restored! Spin the wheel to begin.</p>`;
}

drawWheel(0);
updateCounter();
</script>
